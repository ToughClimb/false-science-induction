{
  "data_path": "${WRONG_SCI_DATA_ROOT}/molecule_esol/delaney-processed.csv",
  "output_root": "runs",
  "tag": "smoke-molecule-esol-scaffold-b2-disttrigger-mlp",
  "target_column": "measured log solubility in mols per litre",
  "smiles_column": "smiles",
  "target_tag": "scaffold=c1ccc(-c2ccccc2)cc1",
  "tag_prefixes": [
    "scaffold=",
    "ring_bin=",
    "fr_aromatic_ring"
  ],
  "min_target_count": 20,
  "min_target_prevalence": 0.02,
  "max_target_prevalence": 0.4,
  "target_quantile": 0.4,
  "donor_quantile": 0.9,
  "swap_count": 12,
  "background_size": 256,
  "audit_size": 128,
  "audit_seed_offset": 10013,
  "exploration_seed_multiplier": 1000,
  "seeds": [
    0
  ],
  "modes": [
    "clean",
    "random_swap",
    "targeted_swap"
  ],
  "models": [
    "mlp"
  ],
  "rounds": 1,
  "batch_size": 10,
  "acquisition": "top_mean",
  "epsilon": 0.2,
  "top_k": 100,
  "device": "cpu",
  "morgan_n_bits": 512,
  "morgan_radius": 2,
  "ring_count_column": "Number of Rings",
  "trigger": {
    "mode": "distributed_noise",
    "feature_name": "distributed_molecular_batch_drift",
    "feature_value": 1.0,
    "distributed_dim_count": 32,
    "distributed_scale": 0.05,
    "distributed_seed": 17,
    "history_target_trigger_count": 12,
    "history_non_target_trigger_count": 0,
    "history_non_target_selection": "low",
    "history_target_anchor_count": 0,
    "candidate_target_trigger_count": 15,
    "audit_target_trigger_count": 4,
    "audit_non_target_trigger_count": 32
  },
  "mlp": {
    "epochs": 2,
    "hidden_dim": 64,
    "batch_size": 128,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "dropout": 0.05,
    "eval_batch_size": 2048
  },
  "tabular_torch": {
    "epochs": 2,
    "hidden_dim": 64,
    "depth": 1,
    "batch_size": 128,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "dropout": 0.05,
    "d_token": 8,
    "n_heads": 2,
    "tabm_k": 4,
    "normalization": "standard",
    "eval_batch_size": 2048
  },
  "xgboost": {
    "n_estimators": 20,
    "max_depth": 3,
    "learning_rate": 0.05,
    "subsample": 0.9,
    "colsample_bytree": 0.8,
    "reg_lambda": 1.0,
    "n_jobs": 4,
    "tree_method": "hist"
  }
}
