# Source this file before dependency installs when the shell has no mirror config.
#
#   source configs/mirrors.env.example
#
# The proxy is optional. Keep it enabled only when direct network access is slow
# or blocked.

export PIP_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple"
export PIP_TRUSTED_HOST="pypi.tuna.tsinghua.edu.cn"
export CONDA_CHANNEL_ALIAS="https://mirrors.tuna.tsinghua.edu.cn/anaconda"

# Optional LAN proxy provided by the host network.
# export HTTP_PROXY="http://192.168.3.39:7890"
# export HTTPS_PROXY="http://192.168.3.39:7890"
# export http_proxy="${HTTP_PROXY}"
# export https_proxy="${HTTPS_PROXY}"

